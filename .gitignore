# ============================================================
# .gitignore — orinoco-forecast
# ML/Python project — datos pesados, entornos, secretos
# ============================================================

# --- Datos pesados (NUNCA subir al repo) ---
data/raw/
data/processed/
data/external/
*.xlsx
*.xls
*.csv
*.parquet
*.nc
*.h5
*.hdf5
*.pkl
*.pickle

# --- Resultados y pesos de modelos ---
results/models/
results/metrics/
results/figures/
*.pt
*.pth
*.pb
*.onnx
*.joblib

# --- MLflow ---
mlruns/
mlartifacts/
.mlflow/

# --- Entornos virtuales ---
.venv/
.venv_wsl/        # Entorno WSL2 — symlinks incompatibles con git en Windows
venv/
env/
ENV/
.env
.env.*
*.env

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
*.whl
pip-log.txt
pip-delete-this-directory.txt

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py
*.nbconvert/

# --- Testing ---
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/
nosetests.xml

# --- IDEs y editores ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Logs ---
logs/
*.log
*.out

# --- CUDA / GPU ---
*.cudnn_session

# --- Agent / SDD local artifacts ---
.atl/

# --- Documentos temporales ---
*.tmp
*.bak
*.orig

# Mantener la estructura de carpetas de datos vacía
!data/.gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep
!results/.gitkeep
!results/models/.gitkeep
!results/metrics/.gitkeep
!results/figures/.gitkeep
!data/raw/legacy_imputed/.gitkeep
